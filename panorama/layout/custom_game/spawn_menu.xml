<root>
	<scripts>
		<include src="file://{resources}/scripts/custom_game/spawn_menu.js" />
	</scripts>
	<styles>
		<include src="s2r://panorama/styles/base_styles.vcss_c" />
		<include src="file://{resources}/styles/custom_game/spawn_menu.css" />
	</styles>
	<ClientUIDialogPanel class="RootPanel">
		<Panel class="HeaderPanel">
			<Label text="Enemy Spawner"/>
		</Panel>
		<Panel class="ContentPanel">
			<Panel class="SpawnerPanel">
				<Panel class="SpawnerPanelHeader">
					<Label text="Arena Capacity: 0/25" id="ArenaCapacityLabel"/>
				</Panel>
				<Panel id="EmptyPanel" class="EmptyPanel">
					
				</Panel>
			</Panel>
			<Panel class="PreviewPanel">
				<Label class="PreviewTitle" text="Preview Title" id="PreviewTitle"/>
				<Panel class="PreviewImagePanel">
					<Image id="PreviewImage" src="file://{images}/custom_game/placeholder_color.png"/>
				</Panel>
				<Panel class="EditButtonsPanel">
					<Panel class="EditButton Subtract" onmouseover="HoverSound()" onactivate="Subtract()">
						<Label text="-"/>
					</Panel>
					<Panel class="PreviewCounterPanel">
						<Label id="PreviewNpcAmount" text="0"/>
					</Panel>
					<Panel class="EditButton Add" onmouseover="HoverSound()" onactivate="Add()">
						<Label text="+"/>
					</Panel>
				</Panel>
			</Panel>
		</Panel>
	</ClientUIDialogPanel>
</root>